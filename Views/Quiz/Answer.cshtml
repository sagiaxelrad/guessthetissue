@{
    ViewData["Title"] = "Answer";
}

<div class="text-center">

    <h1 class="display-4">Answer</h1>

    <br />

    @if (ViewBag.Correct)
    {
        <h2 style="color:green;">Correct!</h2>
    }
    else
    {
        <h2 style="color:red;">Incorrect</h2>
        <p>The correct answer was:</p>
        <h3>@ViewBag.CorrectAnswer</h3>
    }

    <br /><br />

    <a href="/Quiz/Question?id=@ViewBag.NextId" class="btn btn-primary btn-lg">
        Next Question
    </a>

</div>

<br />
<br />

